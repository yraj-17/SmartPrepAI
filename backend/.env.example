# SmartPrepAI backend environment
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:5175

# Use MongoDB Atlas or local MongoDB.
MONGODB_URI=mongodb://127.0.0.1:27017/smartprep_ai

# Change these before deployment.
JWT_ACCESS_SECRET=change_this_access_secret_for_development
JWT_REFRESH_SECRET=change_this_refresh_secret_for_development
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Optional AI provider keys. Leave blank for local/rule-based fallbacks where available.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=8192

# Optional services.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
EMAIL_SERVICE=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=SmartPrepAI
EMAIL_FROM=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
REDIS_URL=redis://localhost:6379

# Code runner settings.
CODE_EXECUTION_SERVICE=piston
PISTON_URL=https://emkc.org/api/v2/piston
JUDGE0_URL=
JUDGE0_API_KEY=

# Python AI server.
PYTHON_AI_SERVER_URL=http://localhost:8000
PYTHON_AI_SERVER_API_KEY=change_this_python_server_key
PYTHON_API_URL=http://localhost:8000

# Upload settings.
MAX_FILE_SIZE=10485760
SUPPORTED_FILE_TYPES=pdf,doc,docx
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
